# feed-it 환경변수 예시
# 실제 값은 .env 에 작성 (.gitignore 대상)
# 생성·발급 절차는 docs/setup.md 참조

# ─────────────────────────────────────────────
# n8n 자체 (docker-compose가 사용)
# ─────────────────────────────────────────────

# n8n UI Basic Auth 계정
N8N_BASIC_AUTH_USER=admin

# 강력한 임의 비밀번호 (32자 이상 권장)
# 생성: PowerShell  →  -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | % {[char]$_})
N8N_BASIC_AUTH_PASSWORD=replace-me

# n8n credential 암호화 키. 한 번 정하면 절대 변경 금지 (변경 시 모든 credential 손실)
# 생성: PowerShell  →  -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | % {[char]$_})
N8N_ENCRYPTION_KEY=replace-me-keep-stable

# ─────────────────────────────────────────────
# 외부 API 키 6종 (n8n credential 화면에 입력)
# ─────────────────────────────────────────────

# Anthropic Claude (Sonnet 4.6)  발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-replace-me

# Firecrawl (웹 스크래핑, 무료 500 page/month)  발급: https://firecrawl.dev/app
FIRECRAWL_API_KEY=fc-replace-me

# Notion Integration  발급: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_replace-me

# Notion DB ID  Notion DB URL의 마지막 32자 (하이픈 제거)
NOTION_DATABASE_ID=replace-me

# Slack Bot User OAuth Token (scope: chat:write)  발급: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-replace-me

# Slack 채널 ID (channel 이름 X — Slack 채널 우클릭 > Copy link 에서 추출)
SLACK_DIGEST_CHANNEL_ID=C00000000
SLACK_ALERTS_CHANNEL_ID=C00000000
