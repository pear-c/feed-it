    {
      "parameters": {
        "jsCode": "const first = $input.first();\nconst key = Object.keys(first.binary || {})[0];\nif (!key) throw new Error('binary 필드 없음 — F-2 출력의 Binary 탭 확인');\n\nconst buffer = await this.helpers.getBinaryDataBuffer(0, key);\nconst text = buffer.toString('utf-8');\nif (!text.trim()) throw new Error('파일 내용이 비어있음 — F-2의 File Selector 경로 확인');\n\nfunction parseVal(v) {\n  v = v.trim();\n  if (v === 'true') return true;\n  if (v === 'false') return false;\n  return v;\n}\n\nconst channels = [];\nlet cur = null;\nfor (const rawLine of text.split('\\n')) {\n  const trimmed = rawLine.replace(/\\r$/, '').trim();\n  if (!trimmed || trimmed.startsWith('#')) continue;\n\n  let m = trimmed.match(/^-\\s+(\\w+):\\s*(.*)$/);\n  if (m) {\n    if (cur) channels.push(cur);\n    cur = { [m[1]]: parseVal(m[2]) };\n    continue;\n  }\n  m = trimmed.match(/^(\\w+):\\s*(.*)$/);\n  if (m && cur) cur[m[1]] = parseVal(m[2]);\n}\nif (cur) channels.push(cur);\n\nreturn channels.map((c) => ({ json: c }));"
      },
