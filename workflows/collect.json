    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nlet text = ((resp.content && resp.content[0] && resp.content[0].text) || '').trim();\n// 마크다운 코드블록 제거 (conventions §1.6 안전망)\ntext = text.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/```\\s*$/i, '').trim();\n\nconst channel = $('payload빌드').first().json.channel;\n\nlet arr;\ntry {\n  arr = JSON.parse(text);\n  if (!Array.isArray(arr)) throw new Error('JSON이 배열 아님');\n} catch (e) {\n  return [{ json: { _parse_error: e.message, raw: text.slice(0, 500), channel } }];\n}\nif (arr.length === 0) return [];\nreturn arr.map((item) => ({ json: { ...item, channel } }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
