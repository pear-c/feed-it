    {
      "parameters": {
        "jsCode": "const pkey = Object.keys($input.first().binary || {})[0];\nif (!pkey) throw new Error('프롬프트 binary 없음 — 프롬프트읽기 노드 확인');\nlet prompt = (await this.helpers.getBinaryDataBuffer(0, pkey)).toString('utf-8');\nprompt = prompt.replace(/^---[\\s\\S]*?---\\s*/, '').trim();   // frontmatter 제거\n\nconst set = $('채널준비').first().json;\nconst fc  = $('Firecrawl수집').first().json;\nconst channel = set.channel;\nconst today_kst = set.today_kst;\nconst markdown = (fc.data && fc.data.markdown) || '';\n\nconst user_content =\n  `channel.name: ${channel.name}\\n` +\n  `channel.type: ${channel.type}\\n` +\n  `channel.domain: ${channel.domain}\\n` +\n  `today_kst: ${today_kst}\\n\\n` +\n  `page_markdown:\\n${markdown}`;\n\nreturn [{ json: { system: prompt, user_content, channel } }];"
      },
