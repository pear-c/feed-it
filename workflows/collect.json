      "parameters": {
        "jsCode": "// 기존 URL 집합 (Notion raw page에서 properties.URL.url)\nconst existing = new Set();\nfor (const it of $input.all()) {\n  const u = it.json?.properties?.URL?.url;\n  if (u) existing.add(u);\n}\n// 후보에서 신규만\nconst candidates = $('후보수집').first().json.candidates || [];\nconst fresh = candidates.filter(c => !existing.has(c.url));\nreturn fresh.map(c => ({ json: c }));"
