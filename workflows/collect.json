    {
      "parameters": {
        "jsCode": "const fresh = $('신규필터').all().map(i => i.json);\nconst total = fresh.length;\nconst byChannel = {};\nfresh.forEach(c => { const n = c.channel?.name || 'unknown'; byChannel[n] = (byChannel[n] || 0) + 1; });\nconst lines = Object.entries(byChannel).map(([n, c]) => `• ${n}: ${c}건`);\nconst ts = $now.setZone('Asia/Seoul').toFormat('yyyy-MM-dd HH:mm');\nreturn [{ json: { text: `:inbox_tray: feed-it 수집 완료 (${ts} KST)\\n신규 ${total}건\\n${lines.join('\\n')}` } }];"
