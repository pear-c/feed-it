    {
      "parameters": {
        "jsCode": "return $input.all().map((it) => {\n  let url = (it.json.url || '').trim();\n  if (!url) return { json: { ...it.json, _skip: true } };\n  url = url.replace(/^http:/, 'https:');\n  try {\n    const u = new URL(url);\n    u.host = u.host.toLowerCase();\n    [...u.searchParams.keys()].filter((k) => k.toLowerCase().startsWith('utm_')).forEach((k) =>\nu.searchParams.delete(k));\n    if (u.pathname.length > 1 && u.pathname.endsWith('/')) u.pathname = u.pathname.slice(0, -1);\n    url = u.toString();\n  } catch (e) { /* 잘못된 URL은 그대로 */ }\n  return { json: { ...it.json, url } };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
